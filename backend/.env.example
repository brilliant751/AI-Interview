# AI-Interview 后端环境变量示例
# 使用方式：cp backend/.env.example backend/.env

AI_INTERVIEW_APP_ENV=dev
AI_INTERVIEW_DB_PATH=backend/assets/data/sqlite/interview.db
AI_INTERVIEW_CHROMA_DIR=backend/assets/data/chroma

AI_INTERVIEW_LLM_PROVIDER=mock
AI_INTERVIEW_LLM_MODEL=deepseek-r1:8b
AI_INTERVIEW_ASR_PROVIDER=funasr
AI_INTERVIEW_ASR_MODEL=paraformer-zh
AI_INTERVIEW_ASR_DEVICE=cpu
AI_INTERVIEW_TTS_PROVIDER=paddlespeech
AI_INTERVIEW_TTS_MODEL=fastspeech2_csmsc
AI_INTERVIEW_TTS_DEVICE=cpu

AI_INTERVIEW_OPENAI_API_KEY=your_api_key_here
AI_INTERVIEW_PROVIDER_BASE_URL=https://open.bigmodel.cn/api/paas/v4/
AI_INTERVIEW_PROVIDER_TRUST_ENV=true

AI_INTERVIEW_OLLAMA_BASE_URL=http://localhost:11434
